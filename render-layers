#!/usr/bin/env ruby

require "fileutils"
require "json"
require "open3"
require "tmpdir"
require "uri"

root = __dir__
keymap = File.read(File.join(root, "config", "go60.keymap"))
output = File.expand_path(ARGV.fetch(0, File.join(root, "layout-preview.html")))

layer_defines = keymap.match(%r{/\* Automatically generated layer name defines \*/(.*?)/\* To deal}m)&.[](1)
raise "Missing generated layer definitions" unless layer_defines
layer_names = layer_defines.scan(/^#define LAYER_(\w+) (\d+)$/).sort_by { |_, index| index.to_i }.map(&:first)

bindings = layer_names.to_h do |name|
  body = keymap.match(/^\s*layer_#{Regexp.escape(name)}\s*\{\s*bindings\s*=\s*<(.*?)>;\s*};/m)&.[](1)
  raise "Missing layer #{name}" unless body

  entries = []
  body.scan(/\S+/).each do |token|
    if token.start_with?("&")
      entries << token
    else
      entries[-1] = "#{entries[-1]} #{token}"
    end
  end
  raise "#{name} has #{entries.length} bindings" unless entries.length == 60

  [name, entries]
end

colors = keymap.scan(/^\s*#define\s+(\w+)_RGB\s+(0x[0-9A-Fa-f]{6})/).to_h.transform_values { |value| "##{value.delete_prefix("0x")}" }
rgb_binding_sets = keymap.scan(/^\s*#define[ \t]+(\w+)[ \t]+\\\n((?:[^\n]*\\\n)*[^\n]*)/).to_h

layers = layer_names.each_with_index.map do |name, layer_index|
  own = bindings.fetch(name).map { |binding| binding == "&trans" ? "0" : "1" }.join
  resolved = bindings.fetch(name).each_index.map do |key_index|
    source = layer_index
    source -= 1 while source.positive? && bindings.fetch(layer_names[source])[key_index] == "&trans"
    bindings.fetch(layer_names[source])[key_index]
  end
  rgb = keymap.match(/^\s*#{Regexp.escape(name)}\s*\{.*?bindings\s*=\s*<(.*?)>;.*?layer-id\s*=\s*<LAYER_#{Regexp.escape(name)}>;/m)
  layer = { name: name, bindings: resolved, own: own }
  if rgb
    source = rgb_binding_sets.fetch(rgb[1].strip, rgb[1])
    tokens = source.scan(/\b(?:___|[A-Z]{3})\b/)
    raise "#{name} has #{tokens.length} RGB bindings" unless tokens.length == 60
    layer[:colors] = tokens.map { |token| token == "___" ? "#000000" : colors.fetch(token) }
  end
  layer
end

template = File.read(File.join(root, "layers.html.erb"))
File.write(output, template.sub("__LAYERS__", JSON.generate(layers)))

browser_names = [
  ENV["BROWSER"],
  "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
  "google-chrome",
  "chromium",
  "chromium-browser"
].compact
browser = browser_names.lazy.map do |name|
  next name if File.executable?(name)

  ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).map { |directory| File.join(directory, name) }.find { |path| File.executable?(path) }
end.find(&:itself)
raise "Set BROWSER to a headless browser executable" unless browser

output_stem = output.delete_suffix(File.extname(output))
images = layers.map { |layer| "#{output_stem}-#{layer[:name].downcase}.png" }
html_url = "file://#{URI::DEFAULT_PARSER.escape(output)}"

Dir.mktmpdir(".go60-layers-", File.dirname(output)) do |directory|
  images.each_with_index do |image, index|
    rendered = File.join(directory, File.basename(image))
    _, error, status = Open3.capture3(
      browser,
      "--headless",
      "--disable-gpu",
      "--hide-scrollbars",
      "--run-all-compositor-stages-before-draw",
      "--force-color-profile=srgb",
      "--force-device-scale-factor=2",
      "--window-size=1070,410",
      "--screenshot=#{rendered}",
      "#{html_url}?snapshot=1&layer=#{index}"
    )
    raise "Failed to render #{image}: #{error.strip}" unless status.success? && File.size?(rendered)
  end

  images.each { |image| FileUtils.mv(File.join(directory, File.basename(image)), image) }
end
(Dir.glob("#{output_stem}-*.png") - images).each { |image| File.delete(image) }

puts output, images
